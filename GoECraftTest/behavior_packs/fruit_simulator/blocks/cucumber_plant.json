{
  "format_version": "1.21.0",
  "minecraft:block": {
    "description": {
      "identifier": "fruit_simulator:cucumber_plant",
      "states": {
        "fruit_simulator:plant_growth": [0, 1, 2, 3, 4]
      }
    },

    "components": {
      "minecraft:destructible_by_mining": true,
      "minecraft:collision_box": false,
      "minecraft:selection_box": true,

      "minecraft:geometry": "geometry.cucumber_plant_0",
      "minecraft:material_instances": {
        "*": {
          "texture": "cucumber_plant_0",
          "render_method": "alpha_test"
        }
      },

      "minecraft:custom_components": ["fruit_simulator:player_grown_plant"]
    },

    "permutations": [
      {
        "condition": "q.block_state('fruit_simulator:plant_growth') == 1",
        "components": {
          "minecraft:geometry": "geometry.cucumber_plant_1",
          "minecraft:material_instances": {
            "*": {
              "texture": "cucumber_plant_1",
              "render_method": "alpha_test"
            }
          }
        }
      },
      {
        "condition": "q.block_state('fruit_simulator:plant_growth') == 2",
        "components": {
          "minecraft:geometry": "geometry.cucumber_plant_2",
          "minecraft:material_instances": {
            "*": {
              "texture": "cucumber_plant_2",
              "render_method": "alpha_test"
            }
          }
        }
      },
      {
        "condition": "q.block_state('fruit_simulator:plant_growth') == 3",
        "components": {
          "minecraft:geometry": "geometry.cucumber_plant_3",
          "minecraft:material_instances": {
            "*": {
              "texture": "cucumber_plant_3",
              "render_method": "alpha_test"
            }
          }
        }
      },
      {
        "condition": "q.block_state('fruit_simulator:plant_growth') == 4",
        "components": {
          "minecraft:geometry": "geometry.cucumber_plant_4",
          "minecraft:material_instances": {
            "*": {
              "texture": "cucumber_plant_4",
              "render_method": "alpha_test"
            }
          }
        }
      }
    ]
  }
}
